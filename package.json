{
  "name": "ai-code-review-bot",
  "version": "1.0.0",
  "description": "GitHub App that automatically reviews pull requests using Claude AI",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "type-check": "tsc --noEmit"
  },
  "keywords": [
    "github",
    "code-review",
    "ai",
    "claude"
