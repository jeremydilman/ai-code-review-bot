{
  "version": 2,
  "builds": [
    {
      "src": "dist/server.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "dist/server.js"
    }
  ],
  "env": {
    "GITHUB_APP_ID": "@github_app_id",
    "GITHUB_PRIVATE_KEY": "@github_private_key",
    "GITHUB_WEBHOOK_SECRET": "@github_webhook_secret",
    "ANTHROPIC_API_KEY": "@anthropic_api_key"
  }
}
